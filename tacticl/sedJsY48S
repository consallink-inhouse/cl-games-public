<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>TACTICL — フォーメーション</title>
<link href="https://fonts.googleapis.com/css2?family=Rajdhani:wght@400;500;600;700&family=Noto+Sans+JP:wght@300;400;500;700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="css/common.css">
<link rel="stylesheet" href="css/formation.css">
</head>
<body>

<div class="app">
  <!-- SIDEBAR -->
  <nav class="sidebar" id="sidebar">
    <div class="logo">
      <a href="index.html">
        <div class="logo-text">⚡ TACTICL</div>
        <div class="logo-sub">社会人サッカー戦術プラットフォーム</div>
      </a>
    </div>

    <div class="nav">
      <div class="nav-section">メイン</div>
      <a class="nav-item" href="index.html">
        <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/></svg>
        ダッシュボード
      </a>
      <a class="nav-item" href="schedule.html">
        <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
        スケジュール
        <span class="nav-badge">3</span>
      </a>

      <div class="nav-section">チーム管理</div>
      <a class="nav-item" href="company.html">
        <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9,22 9,12 15,12 15,22"/></svg>
        会社・チーム管理
      </a>
      <a class="nav-item" href="members.html">
        <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
        メンバー管理
      </a>
      <a class="nav-item active" href="formation.html">
        <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3"/><circle cx="4" cy="8" r="2"/><circle cx="20" cy="8" r="2"/><circle cx="4" cy="18" r="2"/><circle cx="20" cy="18" r="2"/><line x1="6" y1="8" x2="9" y2="11"/><line x1="15" y1="11" x2="18" y2="8"/><line x1="6" y1="18" x2="9" y2="13"/><line x1="15" y1="13" x2="18" y2="18"/></svg>
        フォーメーション
      </a>

      <div class="nav-section">対外活動</div>
      <a class="nav-item" href="companies.html">
        <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
        企業・チーム一覧
      </a>
      <a class="nav-item" href="score.html">
        <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 20h12"/><path d="M12 20V4"/><circle cx="5" cy="10" r="2"/><circle cx="19" cy="7" r="2"/></svg>
        スコア管理
      </a>
      <a class="nav-item" href="records.html">
        <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="22,12 18,12 15,21 9,3 6,12 2,12"/></svg>
        成績管理
      </a>

      <div class="nav-section">コミュニケーション</div>
      <a class="nav-item" href="chat.html">
        <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
        チャット
        <span class="nav-badge">5</span>
      </a>
    </div>

    <div class="sidebar-footer">
      <div class="company-tag">
        <div class="company-avatar">CL</div>
        <div>
          <div class="company-name">株式会社コンサルリンク</div>
          <div class="company-plan">フリープラン</div>
        </div>
      </div>
    </div>
  </nav>

  <!-- SIDEBAR OVERLAY (mobile) -->
  <div class="sidebar-overlay" id="sidebarOverlay" onclick="closeSidebar()"></div>

  <!-- MAIN -->
  <main class="main">
    <div class="topbar">
      <button class="menu-toggle" onclick="toggleSidebar()">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/>
        </svg>
      </button>
      <div class="page-title">フォーメーション</div>
      <div class="topbar-actions">
        <div class="notif-btn">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg>
          <div class="notif-dot"></div>
        </div>
        <button class="btn btn-primary">＋ 新規作成</button>
      </div>
    </div>

    <div class="content">
      <div class="formation-layout">
        <div class="field-container">
          <div class="section-header" style="padding:0 0 16px 0;background:none;border:none">
            <div class="section-title">フォーメーション設定</div>
            <div style="display:flex;gap:8px">
              <button class="btn btn-outline" onclick="clearFormation()">クリア</button>
              <button class="btn btn-primary" onclick="saveFormation()">保存</button>
            </div>
          </div>
          <div class="field" id="soccerField">
            <div class="field-center-line"></div>
            <div class="field-center-circle"></div>
            <div class="field-goal-top"></div>
            <div class="field-goal-bottom"></div>
          </div>
        </div>

        <div class="formation-sidebar">
          <div class="f-card">
            <div class="f-card-title">試合選択</div>
            <select style="width:100%;margin-bottom:10px">
              <option>1/25 vs DigitalForce（練習試合）</option>
              <option>2/2 第3回企業交流大会</option>
            </select>
            <select style="width:100%">
              <option>攻撃時フォーメーション</option>
              <option>守備時フォーメーション</option>
              <option>セットプレー</option>
            </select>
          </div>

          <div class="f-card">
            <div class="f-card-title">フォーメーション</div>
            <div class="formation-preset">
              <div class="preset-btn active" onclick="setFormation('2-2', this)">2-2</div>
              <div class="preset-btn" onclick="setFormation('3-1', this)">3-1</div>
              <div class="preset-btn" onclick="setFormation('1-2-1', this)">1-2-1</div>
              <div class="preset-btn" onclick="setFormation('4-0', this)">4-0</div>
            </div>
            <div style="margin-top:8px">
              <label>戦術メモ</label>
              <textarea style="width:100%;margin-top:6px;font-size:12px;min-height:60px" placeholder="戦術・指示を入力...">高プレスからのショートカウンター。サイドを広く使い展開する。</textarea>
            </div>
          </div>

          <div class="f-card">
            <div class="f-card-title">ベンチメンバー</div>
            <div id="benchPlayers"></div>
          </div>
        </div>
      </div>
    </div>
  </main>
</div>

<script src="js/common.js"></script>
<script src="js/formation.js"></script>
</body>
</html>
